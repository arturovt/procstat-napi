{
  "name": "procstat-napi",
  "version": "0.2.0-alpha.2",
  "license": "Apache-2.0",
  "description": "Linux process statistics via /proc for Node.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arturovt/procstat-napi.git"
  },
  "bugs": {
    "url": "https://github.com/arturovt/procstat-napi/issues"
  },
  "homepage": "https://github.com/arturovt/procstat-napi#readme",
  "main": "./index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.ts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    },
    "./package.json": {
      "default": "./package.json"
    },
    "./index.js": {
      "default": "./index.js"
    },
    "./index.mjs": {
      "default": "./index.mjs"
    }
  },
  "typings": "./index.d.ts",
  "engines": {
    "node": ">=22.16.0"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "README.md",
    "LICENSE",
    "prebuilds/**",
    "src",
    "binding.gyp"
  ],
  "scripts": {
    "install": "node-gyp-build",
    "build:dev": "node-gyp rebuild --debug --gui=1",
    "build:mac": "prebuildify --napi --arch x64+arm64",
    "build:windows": "prebuildify --napi --platform win32 --arch x64+ia32",
    "build:linux": "prebuildify --napi --platform linux --arch x64+ia32",
    "test": "LD_PRELOAD=$(gcc -print-file-name=libasan.so) NODE_OPTIONS=\"--expose-gc\" ava",
    "prepare": "husky"
  },
  "dependencies": {
    "node-addon-api": "^8.6.0",
    "node-gyp-build-esm": "5.0.2"
  },
  "devDependencies": {
    "ava": "^5.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "node-gyp": "9.4.0",
    "prebuildify": "^6.0.0"
  },
  "binary": {
    "napi_versions": [
      8
    ]
  }
}
